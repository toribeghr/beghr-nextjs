# No environment variables required for this deployment
# All configuration is baked into the code for static generation

# GTM ID is configured in src/app/layout.tsx
# GTM_ID=GTM-MVSLWC2S

# Domain configuration (set in Vercel project settings)
# VERCEL_URL=beghr.com

# Compliance template library — Zapier catch-hook that receives each template-download
# lead (routed to a per-category sheet tab by a Zapier Paths step). saveLead() reads this
# at runtime; if unset it logs a warning and skips the POST (document generation is never
# blocked). MUST be set in the Vercel project settings before this goes live.
# ZAPIER_TEMPLATE_LEADS_WEBHOOK_URL=https://hooks.zapier.com/hooks/catch/000000/xxxxxxx/
